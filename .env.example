# CHF Environment Variables
# Copy this file to .env and fill in values as needed.
# All APIs used are FREE — no paid keys required.

# Project root (auto-detected if not set)
# CHF_ROOT=/path/to/chf

# CoinGecko free API (no key required for basic endpoints)
# COINGECKO_API_KEY=  # optional: CoinGecko Demo key for higher rate limits

# CCXT / Binance public endpoints (no key required for market data)
# BINANCE_API_KEY=    # optional: only needed for private endpoints (not used here)
# BINANCE_SECRET=     # optional: only needed for private endpoints (not used here)

# CoinMetrics Community API (no key required)
# COINMETRICS_API_KEY=  # optional: community tier is keyless

# DeFiLlama API (no key required)
# DEFILLAMA_API_KEY=  # not needed

# CoinMarketCap Pro API (optional — needed for pro endpoints / historical quotes)
# COINMARKETCAP_API_KEY=
# CMC_API_KEY=          # alias accepted by some scripts

# Etherscan / The Graph / Dune (optional on-chain providers)
# ETHERSCAN_API_KEY=
# GRAPH_API_KEY=
# DUNE_API_KEY=

# MLflow tracking URI (default: local mlruns/ directory)
MLFLOW_TRACKING_URI=mlruns

# Random seed for reproducibility
CHF_SEED=42

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
